# Copy this file to .env and replace every password before starting the stack.

# Bind MLflow to localhost by default. Set this to your VPN interface IP on the VPS
# if you want other machines on the VPN to reach it directly.
MLFLOW_HOST=127.0.0.1
MLFLOW_PORT=5000

# Optional MinIO console/API exposure for administration. MLflow clients do not
# need these ports when proxied artifacts are enabled.
MINIO_HOST=127.0.0.1
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

POSTGRES_USER=mlflow
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=mlflow

MINIO_ROOT_USER=mlflow
MINIO_ROOT_PASSWORD=change-me-minio-password
MLFLOW_ARTIFACT_BUCKET=mlflow-artifacts
